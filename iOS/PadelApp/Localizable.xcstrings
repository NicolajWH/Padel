            "value": "Sæt %lld"
          }
        }
      }
    },
    "Set up a group, rotate partners automatically, and add up everyone's individual points — just like Americano padel, right on your Apple Watch.": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Opret en gruppe, rotér makkere automatisk, og læg alles individuelle point sammen — præcis som Americano-padel, direkte på dit Apple Watch."
          }
        }
      }
    },
