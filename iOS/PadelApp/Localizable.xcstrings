      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Ikke installeret"
          }
        }
      }
    },
    "Not Reachable": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Ikke tilgængeligt"
          }
        }
      }
    },
    "Number of rounds: %lld": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Antal runder: %lld"
          }
        }
      }
    },
    "OK": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "OK"
          }
        }
      }
    },
    "Only needed if automatic discovery can't find the match.": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Kun nødvendig, hvis automatisk søgning ikke kan finde kampen."
          }
        }
      }
    },
    "Open MATCHi": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Åbn MATCHi"
          }
        }
      }
    },
    "Padel follows your iPhone's language. To use a different language just for this app, change it in Settings. Your Apple Watch follows automatically.": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Padel følger din iPhones sprog. Vil du bruge et andet sprog kun til denne app, kan du ændre det i Indstillinger. Dit Apple Watch følger automatisk med."
          }
        }
      }
    },
    "Padel — score matches with real padel rules, run Americano and Mexicano tournaments, and play it all from your Apple Watch.": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Padel — før score med rigtige padelregler, afvikl Americano- og Mexicano-turneringer, og styr det hele fra dit Apple Watch."
          }
        }
      }
    },
    "Partner Chemistry": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Makkerkemi"
          }
        }
      }
    },
    "Partners and opponents rotate so everyone plays with everyone. All rounds are drawn up front.": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Makkere og modstandere roterer, så alle spiller med alle. Alle runder lægges fast fra start."
          }
        }
      }
    },
    "Partners rotate every round, so you play with — and against — everyone in the group.": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Makkerne roterer hver runde, så du spiller med — og mod — alle i gruppen."
          }
        }
      }
    },
    "Paste names, one per line": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Indsæt navne, ét pr. linje"
          }
        }
      }
    },
    "Paste your friends list from another app (e.g. MATCHi) — one name per line — or scan a screenshot of the list and the names are read for you. Review them here before adding; names you already have are skipped.": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Indsæt din venneliste fra en anden app (f.eks. MATCHi) — ét navn pr. linje — eller scan et skærmbillede af listen, så læses navnene for dig. Gennemse dem her, før du tilføjer; navne du allerede har, springes over."
          }
        }
      }
    },
    "Pick your name so your standings row is highlighted on your phone.": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Vælg dit navn, så din række i stillingen fremhæves på din telefon."
          }
        }
      }
    },
    "Play": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Spil"
          }
        }
      }
    },
    "Player %lld": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Spiller %lld"
          }
        }
      }
    },
    "Player 1": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Spiller 1"
          }
        }
      }
    },
    "Player 2": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Spiller 2"
          }
        }
      }
    },
    "Players": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Spillere"
          }
        }
      }
    },
    "Players Nearby": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Spillere i nærheden"
          }
        }
      }
    },
    "Players who have Padel open nearby appear here automatically — tap a name to add it.": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Spillere i nærheden, som har Padel åben, vises her automatisk — tryk på et navn for at tilføje det."
          }
        }
      }
    },
    "Players (min. 4, multiples of 4 work best)": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
