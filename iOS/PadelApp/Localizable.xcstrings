      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Officiel rating (1-7)"
          }
        }
      }
    },
    "Set the player's official padel rating, as on MATCHi. The rating then adjusts automatically after each match and Americano round.": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Angiv spillerens officielle padelrating som på MATCHi. Ratingen justeres derefter automatisk efter hver kamp og Americano-runde."
          }
        }
      }
