      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Live kamp"
          }
        }
      }
    },
    "Looking for players nearby…": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Leder efter spillere i nærheden…"
          }
        }
      }
    },
    "Location access is needed to find matches near you. Enable it for Padel in Settings, or join with a code below.": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Der kræves adgang til lokation for at finde kampe i nærheden. Slå det til for Padel i Indstillinger, eller deltag med en kode nedenfor."
          }
        }
      }
    },
    "Location access is off, so nearby players will need the code to join. You can enable location for Padel in Settings.": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Lokation er slået fra, så spillere i nærheden skal bruge koden for at deltage. Du kan slå lokation til for Padel i Indstillinger."
          }
        }
      }
    },
    "Match Code": {
      "localizations": {
