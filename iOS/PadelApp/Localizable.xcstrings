          }
        }
      }
    },
    "Visible to Players Nearby": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Synlig for spillere i nærheden"
          }
        }
      }
    },
    "When on, players at the same court can see your name and add you to a match or Americano with one tap. Your name and approximate location are shared through iCloud while you use the app.": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Når slået til, kan spillere på samme bane se dit navn og tilføje dig til en kamp eller Americano med ét tryk. Dit navn og din omtrentlige placering deles via iCloud, mens du bruger appen."
          }
        }
      }
    },
    "Who are you?": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Hvem er du?"
          }
        }
      }
    },
