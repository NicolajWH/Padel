          "stringUnit": {
            "state": "translated",
            "value": "Del kamp"
          }
        }
      }
    },
    "Share this Americano so everyone at the venue can follow the standings and score their own court live.": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Del denne Americano, så alle i centret kan følge stillingen og føre score på deres egen bane live."
          }
        }
      }
    },
    "Share this match so everyone on court can follow and update the score live from their own iPhone and Apple Watch.": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Del kampen, så alle på banen kan følge og opdatere scoren live fra deres egen iPhone og Apple Watch."
          }
        }
      }
    },
    "Shared Americano": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Delt Americano"
          }
        }
      }
    },
