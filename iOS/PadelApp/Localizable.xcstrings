    "Players: %lld · Courts per round: %lld · %lld sit out each round — sit-outs rotate fairly so everyone plays the same number of rounds.": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Spillere: %1$lld · Baner pr. runde: %2$lld · %3$lld sidder over hver runde — oversiddere roterer fair, så alle spiller lige mange runder."
          }
