    "No Americano sessions yet": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Ingen Americano-sessioner endnu"
          }
        }
      }
    },
    "No internet connection. Try again when you're back online.": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Ingen internetforbindelse. Prøv igen, når du er online."
          }
        }
      }
    },
    "No matches found nearby. Ask the player keeping score to turn on sharing in the live match.": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Ingen kampe fundet i nærheden. Bed den spiller, der fører score, om at slå deling til i live-kampen."
          }
        }
      }
    },
    "No matches yet": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Ingen kampe endnu"
          }
        }
      }
    },
