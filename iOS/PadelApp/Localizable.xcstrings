      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Delt kamp"
          }
        }
      }
    },
    "Sharing Failed": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Deling mislykkedes"
          }
        }
      }
    },
    "Sharing is on. Players nearby can now join this Americano, pick who they are, and score their own court.": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Deling er slået til. Spillere i nærheden kan nu deltage i denne Americano, vælge hvem de er og føre score på deres egen bane."
          }
        }
      }
    },
    "Sharing is on. Players nearby can now join this match from the Play tab.": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Deling er slået til. Spillere i nærheden kan nu deltage i kampen fra Spil-fanen."
          }
        }
      }
    },
