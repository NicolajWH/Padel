    "Your Name": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Dit navn"
          }
        }
      }
    },
    "Use %@": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Brug %@"
          }
        }
      }
    },
    "Used to suggest who you are when you join a shared Americano. If this is empty, Padel fills it from your iPhone name in Settings when possible.": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Bruges til at foreslå, hvem du er, når du deltager i en delt Americano. Hvis feltet er tomt, udfylder Padel det med navnet fra dine iPhone-indstillinger, når det er muligt."
          }
        }
      }
    },
    "Rating %@ · %lld rated games": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Rating %1$@ · %2$lld ratede kampe"
          }
        }
      }
    },
    "Starting rating %@": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Startrating %@"
          }
        }
      }
    },
    "Ratings use the official 1–7 padel scale, like MATCHi. They start from a player's rating and move after every match and Americano round — beating a stronger team counts for more.": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Ratings bruger den officielle 1-7 padelskala som på MATCHi. De tager udgangspunkt i spillerens rating og ændrer sig efter hver kamp og Americano-runde — at slå et stærkere hold tæller mere."
          }
        }
      }
    },
    "Set official rating": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Angiv officiel rating"
          }
        }
      }
    },
