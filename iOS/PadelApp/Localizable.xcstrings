      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Ingen kampe endnu"
          }
        }
      }
    },
    "No rated games yet": {
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Ingen ratede kampe endnu"
          }
        }
      }
    },
