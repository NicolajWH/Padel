default_platform(:ios)

platform :ios do
  desc "Build the Padel app and upload it to TestFlight"
  lane :beta do
    require "base64"
    require "openssl"
    require "shellwords"

    required_env = %w[
      APPLE_TEAM_ID
      APP_STORE_CONNECT_KEY_ID
      APP_STORE_CONNECT_ISSUER_ID
      APP_STORE_CONNECT_KEY_CONTENT
      MATCH_PASSWORD
      GITHUB_TOKEN
    ]
    missing = required_env.select { |key| ENV[key].to_s.strip.empty? }
    unless missing.empty?
      UI.user_error!(
        "Missing or empty required secret(s): #{missing.join(', ')}. " \
        "Check that these are set under the repository's Settings -> Secrets and variables -> " \
        "Actions, with exactly these names, and that APP_STORE_CONNECT_KEY_CONTENT holds the " \
        "base64-encoded contents of the .p8 key file (see README.md)."
      )
    end

    # Secrets pasted into GitHub often pick up stray whitespace/newlines; a newline
    # inside the key ID or issuer ID silently corrupts the xcodebuild arguments and
    # surfaces as an unrelated-looking "Invalid authentication key credential" error.
    team_id = ENV["APPLE_TEAM_ID"].strip
    key_id = ENV["APP_STORE_CONNECT_KEY_ID"].strip
    issuer_id = ENV["APP_STORE_CONNECT_ISSUER_ID"].strip
    raw_key_secret = ENV["APP_STORE_CONNECT_KEY_CONTENT"].strip

    # Accept the key in any form people actually paste: the raw PEM text of the
    # .p8 file, base64 of the whole file, or just the file's inner base64 body
    # (which decodes to raw DER - Ruby's OpenSSL happily reads DER, which is why
    # fastlane's own JWT minting worked while Xcode's PEM-only parser rejected
    # the same bytes with keyPathInvalid). Re-emit as canonical PKCS#8 PEM so the
    # file on disk is always exactly what Xcode expects.
    key_obj =
      begin
        OpenSSL::PKey.read(raw_key_secret)
      rescue OpenSSL::PKey::PKeyError
        begin
          OpenSSL::PKey.read(Base64.decode64(raw_key_secret))
        rescue OpenSSL::PKey::PKeyError => e
          UI.user_error!(
            "APP_STORE_CONNECT_KEY_CONTENT does not decode to a valid .p8 private key " \
            "(#{e.message}). Set the secret to the raw contents of the AuthKey_*.p8 " \
            "file or its base64 encoding (base64 -i AuthKey_XXXX.p8)."
          )
        end
      end
    key_pem = key_obj.respond_to?(:private_to_pem) ? key_obj.private_to_pem : key_obj.to_pem

    api_key = app_store_connect_api_key(
      key_id: key_id,
      issuer_id: issuer_id,
      key_content: key_pem,
      is_key_content_base64: false,
      in_house: false
    )

    # Prove the key works against the App Store Connect REST API before spending
    # minutes building. This cleanly separates "the key/ID pair is wrong" from the
    # stricter requirements of Xcode's cloud-signing service (which additionally
    # needs a *team* key, not an individual key).
    require "spaceship"
    begin
      Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.from(hash: api_key)
      app = Spaceship::ConnectAPI::App.find("com.worsa.padel")
      if app
        UI.success("App Store Connect API auth OK - found app '#{app.name}' (#{app.bundle_id})")
      else
        UI.important("App Store Connect API auth OK, but no app record found for com.worsa.padel")
      end
    rescue => e
      UI.user_error!(
        "The App Store Connect API rejected the key: #{e.message}. Check that " \
        "APP_STORE_CONNECT_KEY_ID is the ID of the new key (the XXXXXXXXXX in " \
        "AuthKey_XXXXXXXXXX.p8), that the key is a Team Key with the Admin role " \
        "(App Store Connect -> Users and Access -> Integrations -> Team Keys), " \
        "and allow a newly created key a few minutes to propagate."
      )
    end

    build_number = ENV["GITHUB_RUN_NUMBER"] || Time.now.strftime("%Y%m%d%H%M")

    increment_build_number(
      xcodeproj: "Padel.xcodeproj",
      build_number: build_number
    )

    # Ephemeral CI runners never have last run's private key, so Xcode's
    # cloud signing minted a brand-new "Created via API" development
    # certificate on every run until the account hit its certificate cap.
    # match instead keeps ONE Apple Distribution certificate + the App Store
    # profiles for both bundle ids, encrypted with MATCH_PASSWORD on this
    # repo's "certificates" branch, and reuses them on every run.
    setup_ci

    git_basic_authorization = Base64.strict_encode64("x-access-token:#{ENV['GITHUB_TOKEN']}")

    match(
      type: "appstore",
      app_identifier: ["com.worsa.padel", "com.worsa.padel.watchapp", "com.worsa.padel.widgets"],
      api_key: api_key,
      storage_mode: "git",
      git_url: "https://github.com/NicolajWH/Padel.git",
      git_branch: "certificates",
      git_basic_authorization: git_basic_authorization,
      readonly: false,
      platform: "ios"
    )

    ios_profile = ENV["sigh_com.worsa.padel_appstore_profile-name"]
    watch_profile = ENV["sigh_com.worsa.padel.watchapp_appstore_profile-name"]
    widgets_profile = ENV["sigh_com.worsa.padel.widgets_appstore_profile-name"]

    # xcodegen writes CODE_SIGN_STYLE=Automatic; flip both app targets to
    # manual signing with the match distribution identity + profiles so the
    # archive never needs to create certificates.
    update_code_signing_settings(
      path: "Padel.xcodeproj",
      use_automatic_signing: false,
      team_id: team_id,
      code_sign_identity: "Apple Distribution",
      targets: ["PadelApp"],
      profile_name: ios_profile
    )
    update_code_signing_settings(
      path: "Padel.xcodeproj",
      use_automatic_signing: false,
      team_id: team_id,
      code_sign_identity: "Apple Distribution",
      targets: ["PadelWatch"],
      profile_name: watch_profile
    )
    update_code_signing_settings(
      path: "Padel.xcodeproj",
      use_automatic_signing: false,
      team_id: team_id,
      code_sign_identity: "Apple Distribution",
      targets: ["PadelWidgets"],
      profile_name: widgets_profile
    )

    build_app(
      scheme: "PadelApp",
      project: "Padel.xcodeproj",
      configuration: "Release",
      export_method: "app-store",
      clean: true,
      xcargs: "DEVELOPMENT_TEAM=#{team_id.shellescape}",
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        teamID: team_id,
        provisioningProfiles: {
          "com.worsa.padel" => ios_profile,
          "com.worsa.padel.watchapp" => watch_profile,
          "com.worsa.padel.widgets" => widgets_profile
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end
end
