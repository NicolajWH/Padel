default_platform(:ios)

platform :ios do
  desc "Build the Padel app and upload it to TestFlight"
  lane :beta do
    require "base64"
    require "openssl"
    require "shellwords"

    required_env = %w[
      APPLE_TEAM_ID
      APP_STORE_CONNECT_KEY_ID
      APP_STORE_CONNECT_ISSUER_ID
      APP_STORE_CONNECT_KEY_CONTENT
    ]
    missing = required_env.select { |key| ENV[key].to_s.strip.empty? }
    unless missing.empty?
      UI.user_error!(
        "Missing or empty required secret(s): #{missing.join(', ')}. " \
        "Check that these are set under the repository's Settings -> Secrets and variables -> " \
        "Actions, with exactly these names, and that APP_STORE_CONNECT_KEY_CONTENT holds the " \
        "base64-encoded contents of the .p8 key file (see README.md)."
      )
    end

    # Secrets pasted into GitHub often pick up stray whitespace/newlines; a newline
    # inside the key ID or issuer ID silently corrupts the xcodebuild arguments and
    # surfaces as an unrelated-looking "Invalid authentication key credential" error.
    team_id = ENV["APPLE_TEAM_ID"].strip
    key_id = ENV["APP_STORE_CONNECT_KEY_ID"].strip
    issuer_id = ENV["APP_STORE_CONNECT_ISSUER_ID"].strip
    raw_key_secret = ENV["APP_STORE_CONNECT_KEY_CONTENT"].strip

    # Accept the .p8 either base64-encoded (as documented) or pasted as raw PEM,
    # and fail with a precise message if it parses as neither.
    key_pem =
      if raw_key_secret.include?("BEGIN PRIVATE KEY")
        raw_key_secret
      else
        Base64.decode64(raw_key_secret)
      end
    # Ruby's OpenSSL tolerates CRLF line endings in PEM but Xcode's own JWT key
    # parser does not - a .p8 that passed through a Windows/text editor before
    # being base64-encoded fails xcodebuild with JWT.Error.keyPathInvalid while
    # working fine for fastlane itself.
    key_pem = key_pem.gsub(/\r\n?/, "\n")
    key_pem += "\n" unless key_pem.end_with?("\n")
    begin
      OpenSSL::PKey.read(key_pem)
    rescue OpenSSL::PKey::PKeyError => e
      UI.user_error!(
        "APP_STORE_CONNECT_KEY_CONTENT does not decode to a valid .p8 private key " \
        "(#{e.message}). Set the secret to either the raw contents of the AuthKey_*.p8 " \
        "file or its base64 encoding (base64 -i AuthKey_XXXX.p8)."
      )
    end

    api_key = app_store_connect_api_key(
      key_id: key_id,
      issuer_id: issuer_id,
      key_content: key_pem,
      is_key_content_base64: false,
      in_house: false
    )

    build_number = ENV["GITHUB_RUN_NUMBER"] || Time.now.strftime("%Y%m%d%H%M")

    increment_build_number(
      xcodeproj: "Padel.xcodeproj",
      build_number: build_number
    )

    # xcodebuild's own automatic-signing provisioning lookup (-allowProvisioningUpdates)
    # needs its own App Store Connect API key auth - there's no interactive Apple ID
    # signed into Xcode on a CI runner. app_store_connect_api_key holds the key purely
    # in memory when given key_content, so write the .p8 to disk ourselves, in the
    # directory and AuthKey_<ID>.p8 name Xcode conventionally looks keys up under.
    require "fileutils"
    private_keys_dir = File.expand_path("~/.appstoreconnect/private_keys")
    FileUtils.mkdir_p(private_keys_dir)
    auth_key_path = File.join(private_keys_dir, "AuthKey_#{key_id}.p8")
    File.write(auth_key_path, key_pem)

    # Safe diagnostics: file size plus the first 32 bytes, which is only the
    # "-----BEGIN PRIVATE KEY-----" armor line - never key material. od -c makes
    # any stray \r or BOM visible in the build log.
    UI.message("Wrote #{auth_key_path} (#{File.size(auth_key_path)} bytes)")
    sh("od -c #{auth_key_path.shellescape} | head -2")
    sh("openssl pkey -in #{auth_key_path.shellescape} -noout && echo 'openssl parses the .p8 key OK'")

    auth_args = "-allowProvisioningUpdates " \
                "-authenticationKeyPath #{auth_key_path.shellescape} " \
                "-authenticationKeyID #{key_id.shellescape} " \
                "-authenticationKeyIssuerID #{issuer_id.shellescape}"

    build_app(
      scheme: "PadelApp",
      project: "Padel.xcodeproj",
      configuration: "Release",
      export_method: "app-store",
      clean: true,
      xcargs: "#{auth_args} DEVELOPMENT_TEAM=#{team_id.shellescape}",
      export_xcargs: auth_args,
      export_options: {
        method: "app-store",
        signingStyle: "automatic",
        teamID: team_id
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end
end
